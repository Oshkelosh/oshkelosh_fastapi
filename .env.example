# ──────────────────────────────────────────────────────────────────────
# Oshkelosh Environment Variables
# Copy to .env and fill in your values.
# ──────────────────────────────────────────────────────────────────────

# Application
APP_ENV=development
DEBUG=true

# ── Deployment profile (optional preset) ─────────────────────────────
# local              → SQLite (data/oshkelosh.db) + local media (data/uploads)
# cloudflare_remote  → D1 HTTP API + R2 S3 API (Docker/VPS/Railway)
# cloudflare_workers → D1/R2 Workers bindings (stub — not yet implemented)
DEPLOYMENT_PROFILE=local

# Or set backends explicitly (ignored when DEPLOYMENT_PROFILE is set):
# DATABASE_BACKEND=sqlite
# STORAGE_BACKEND=local

# ── Cloudflare D1 (database_backend=d1_http) ─────────────────────────
D1_ACCOUNT_ID=
D1_DATABASE_ID=
D1_DATABASE_NAME=
D1_API_TOKEN=

# ── Cloudflare R2 (storage_backend=r2) ───────────────────────────────
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=oshkelosh-media
# R2_PUBLIC_BASE_URL=https://your-cdn.example.com

# ── JWT & admin session ───────────────────────────────────────────────
# Dev default below is intentional; production startup rejects the placeholder.
JWT_SECRET_KEY=change-me-in-production
JWT_REFRESH_SECRET_KEY=
ADMIN_SESSION_SECRET=
BCRYPT_ROUNDS=12
RATE_LIMIT_ENABLED=true
RATE_LIMIT_LOGIN=5/minute
RATE_LIMIT_REGISTER=3/hour
RATE_LIMIT_REFRESH=10/minute
RATE_LIMIT_ADMIN_LOGIN=5/minute
# Behind NGINX/another reverse proxy, set to the proxy IP so rate limits use the real client IP (e.g. 127.0.0.1)
TRUSTED_PROXY_IPS=
# ADMIN_COOKIE_SAMESITE=lax
PENDING_ORDER_EXPIRY_HOURS=48
ORDER_IDEMPOTENCY_TTL_HOURS=24
FLASH_COOKIE_MAX_AGE=60
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7
PUBLIC_APP_URL=http://localhost:8000
# Canonical public storefront URL (links, sitemap, payment redirects, email links, local media URLs).
# Must match OAuth redirect URIs when using SSO.
REQUIRE_EMAIL_VERIFICATION=true
EMAIL_VERIFICATION_EXPIRE_HOURS=24
PASSWORD_RESET_EXPIRE_HOURS=1

# ── CORS ─────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# ── Addon install / host self-update ─────────────────────────────────
# ADDON_INSTALL_MAX_BYTES=26214400
# ADDON_INSTALL_ALLOWED_HOSTS=
# ADDON_INSTALL_RESTART_FLAG_FILE=data/restart.flag
# ADDON_INSTALL_RESTART_FLAG_FORMAT=json
# Allow Admin → Update Oshkelosh (git pull --ff-only + pip install -e .)
HOST_SELF_UPDATE_ENABLED=false
# HOST_REPO_ROOT=
