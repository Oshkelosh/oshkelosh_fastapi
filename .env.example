# ──────────────────────────────────────────────────────────────────────
# Oshkelosh Environment Variables
# Copy to .env and fill in your values.
# ──────────────────────────────────────────────────────────────────────

# Application
APP_NAME="Oshkelosh"
APP_ENV=development
DEBUG=true

# Optional: create first admin via CLI instead of /setup in the browser
# ADMIN_EMAIL=admin@example.com
# ADMIN_PASSWORD=YourSecurePass123!

# ── Deployment profile (optional preset) ─────────────────────────────
# local              → SQLite + local filesystem (default dev setup)
# cloudflare_remote  → D1 HTTP API + R2 S3 API (Docker/VPS/Railway)
# cloudflare_workers → D1/R2 Workers bindings (stub — not yet implemented)
DEPLOYMENT_PROFILE=local

# Or set backends explicitly (ignored when DEPLOYMENT_PROFILE is set):
# DATABASE_BACKEND=sqlite
# STORAGE_BACKEND=local

# ── SQLite (database_backend=sqlite) ─────────────────────────────────
D1_LOCAL_DB_PATH=data/oshkelosh.db

# ── Local media (storage_backend=local) ────────────────────────────────
LOCAL_MEDIA_DIR=data/uploads
LOCAL_MEDIA_BASE_URL=http://localhost:8000/media/files

# ── Cloudflare D1 (database_backend=d1_http) ─────────────────────────
D1_ACCOUNT_ID=
D1_DATABASE_ID=
D1_DATABASE_NAME=
D1_API_TOKEN=

# ── Cloudflare R2 (storage_backend=r2) ───────────────────────────────
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=oshkelosh-media
# R2_PUBLIC_BASE_URL=https://your-cdn.example.com

# ── JWT & admin session ───────────────────────────────────────────────
JWT_SECRET_KEY=change-me-in-production
JWT_REFRESH_SECRET_KEY=
ADMIN_SESSION_SECRET=
BCRYPT_ROUNDS=12
RATE_LIMIT_ENABLED=true
RATE_LIMIT_LOGIN=5/minute
RATE_LIMIT_REGISTER=3/hour
RATE_LIMIT_REFRESH=10/minute
FLASH_COOKIE_MAX_AGE=60
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ── CORS ─────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# ── Addon install (admin dashboard) ───────────────────────────────────
# APP_VERSION=0.1.0
# ADDON_INSTALL_MAX_BYTES=26214400
# ADDON_INSTALL_ALLOWED_HOSTS=
# After addon install, write a restart flag (default: data/restart.flag).
# Run scripts/watch_addon_restart.py alongside the server to restart automatically.
# ADDON_INSTALL_RESTART_FLAG_FILE=data/restart.flag
# ADDON_INSTALL_RESTART_FLAG_FORMAT=json
# ADDON_INSTALL_RESTART_COMMAND=systemctl restart oshkelosh
# Disable the flag: ADDON_INSTALL_RESTART_FLAG_FILE=

# ── Integrations (Postmark, Printful, Stripe) ─────────────────────────
# Configure in the admin panel after first login — not via .env:
#   /admin/addons  →  enable addon  →  Configure
#   Stripe:    /admin/payments/stripe
#   Printful:  /admin/suppliers/printful
#   Postmark:  /admin/notifications/email
